package main

import (
	"context"
	"fmt"
	"log"
	"time"

	"github.com/abtransitionit/go-core/resource"
)

func run_save_v6() error {
	// define context
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()

	// define the resource location/uri
	resUri := "file:///tmp/config.yaml"
	// uri := "https://example.com/config.yaml"
	// uri := "s3://my-bucket/config.yaml"

	// get a resource manager (saver)
	resSaver, err := resource.NewSaver(resUri)
	if err != nil {
		panic(err)
	}

	// define the data to save into the resource
	data := []byte("hello URI-based FS Savero")

	// save the data into the resource
	err = resSaver.Save(context.Background(), data)
	if err != nil {
		log.Fatal(err)
	}

	// get a resource manager (loader)
	resLoader, err := resource.NewLoader(resUri)
	if err != nil {
		panic(err)
	}

	// get content from resource
	data, err = resLoader.Load(ctx)
	if err != nil {
		log.Fatal(err)
	}

	// print resources
	fmt.Println(string(data))

	// handle success
	return nil
}
